# Margin configuration — copy to .env and edit
PORT=8787

# Public base URL used in the links the agent gets back.
# Locally this is fine; when reviewing from your phone, point it at a tunnel
# (e.g. a Cloudflare/ngrok URL) or your deployed host so the link is reachable
# from any device — that is what makes it "context-agnostic" per the PRD.
PUBLIC_BASE_URL=http://localhost:8787

# Auth — all OPTIONAL (agent-first). Leave unset and the agent self-provisions:
# POST /api/docs creates a doc with no credential and returns a per-document
# capability token + a reviewer link. Set these only if you want extras:
#   AGENT_API_KEY   — a global agent key that can publish to any id
#   REVIEWER_TOKEN  — an owner master: read every doc + the docs index
# Generate strong random values if you use them: $(openssl rand -hex 24)
# (A literal "change-me" value on a non-localhost PUBLIC_BASE_URL is refused.)
AGENT_API_KEY=
REVIEWER_TOKEN=

# Signing secret for the per-document tokens. If unset, the server generates one
# on first use and persists it to the store (no human needed). Set it to keep
# links valid across a store reset:
#   MARGIN_SECRET=$(openssl rand -hex 32)
# MARGIN_LINK_TTL_DAYS makes reviewer links expire (0 = never).
MARGIN_SECRET=
MARGIN_LINK_TTL_DAYS=0

# Open-create rate limit (KV-backed deploys only): max new docs per IP per window.
#   MARGIN_CREATE_MAX=30
#   MARGIN_CREATE_WINDOW=3600

# Storage backend.
#   (unset) → JSON files on disk (local dev), written under DATA_DIR
#   kv      → Vercel KV / Upstash Redis (required on the serverless deploy —
#             the filesystem there is read-only and not shared between requests)
STORE=
DATA_DIR=./data

# --- Vercel / KV (serverless deploy) ---
# On Vercel you do NOT use a .env file — set these in the Vercel project's
# Environment Variables instead. Listed here so the full set is documented.
#
# Provision "Upstash for Redis" from the Vercel Marketplace and connect it to
# the project; Vercel then injects KV_REST_API_URL + KV_REST_API_TOKEN
# automatically. Native Upstash naming (UPSTASH_REDIS_REST_URL /
# UPSTASH_REDIS_REST_TOKEN) is also accepted.
#   STORE=kv
#   KV_REST_API_URL=...        # injected by the Vercel KV / Upstash integration
#   KV_REST_API_TOKEN=...      # injected by the Vercel KV / Upstash integration
#
# Set PUBLIC_BASE_URL to your stable production domain so reviewer links don't
# change every deploy (e.g. https://margin.fieldspan.ai). If unset, the
# per-deployment VERCEL_URL is used as a fallback.
#
# Long-poll (/api/docs/:id/wait) window in ms. Keep it under the function's
# maxDuration in vercel.json (60s). Default 25s.
#   MARGIN_WAIT_MS=25000
